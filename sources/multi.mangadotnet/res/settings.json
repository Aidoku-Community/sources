[
	{
		"type": "group",
		"title": "Settings",
		"items": [
			{
				"type": "switch",
				"key": "hideNSFW",
				"title": "Hide NSFW Content",
				"default": true,
				"refreshes": [
					"content",
					"filters"
				]
			},
			{
				"type": "switch",
				"key": "dedupedChapter",
				"title": "Deduplicate Chapters",
				"default": false,
				"refreshes": [
					"content"
				]
			},
			{
				"type": "switch",
				"key": "showVolumes",
				"title": "Show Standalone Volumes",
				"default": false,
				"refreshes": [
					"content"
				]
			}
		],
		"footer": "Official chapters are preferred, followed by the most recent. Warning: It can be slow on large lists."
	},
	{
		"type": "group",
		"title": "Account",
		"items": [
			{
				"type": "login",
				"method": "web",
				"url": "https://mangadot.net/login?redirect=/",
				"key": "login",
				"title": "Login",
				"logoutTitle": "Logout",
				"notification": "login",
				"refreshes": [
					"content",
					"listings"
				]
			}
		],
		"footer": "Log in to your MangaDot account to view your saved content in the Bookmark listing"
	},
	{
		"type": "group",
		"title": "Deduplicate Preference",
		"items": [
			{
				"type": "editable-list",
				"key": "deduplicateGroupList",
				"title": "Group Preference",
				"placeholder": "Enter Group Id (Ex: 16791)",
				"default": [],
				"refreshes": [
					"content"
				]
			},
			{
				"type": "button",
				"key": "resetDeduplicateGroupList",
				"title": "Reset Group Preference",
				"confirmTitle": "Reset Group Preference",
				"confirmText": "Are you sure you want to remove all configured group preference?",
				"destructive": true,
				"notification": "resetDeduplicateGroupList",
				"refreshes": [
					"content"
				]
			}
		],
		"footer": "This helps to narrow down groups that you prefer when Deduplicate Chapters are active."
	},
	{
		"type": "group",
		"items": [
			{
				"type": "page",
				"key": "contentFilters",
				"title": "Content Filters",
				"items": [
					{
						"type": "group",
						"items": [
							{
								"type": "multi-select",
								"key": "contentTypes",
								"title": "Content Types",
								"titles": [
									"Manga",
									"Manhwa",
									"Manhua"
								],
								"values": [
									"JP",
									"KR",
									"CN,TW"
								],
								"default": [
									"JP",
									"KR",
									"CN,TW"
								],
								"refreshes": [
									"content"
								]
							}
						]
					}
				]
			},
			{
				"type": "button",
				"key": "resetFilters",
				"title": "Reset Filters",
				"confirmTitle": "Reset Filters",
				"confirmText": "Are you sure you want to remove all configured content filters?",
				"destructive": true,
				"notification": "resetFilters",
				"refreshes": [
					"content"
				]
			}
		],
		"footer": "Content filters are applied to the home page and listings only."
	}
]
